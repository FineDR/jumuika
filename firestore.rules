rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSignedIn() {
      return request.auth != null;
    }

    match /events/{eventId} {
      allow read, write: if isSignedIn();
    }

    match /contributors/{contributorId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() 
        && request.resource.data.fullName is string
        && request.resource.data.totalScheduled >= 0
        && request.resource.data.totalPaid >= 0
        && request.resource.data.remainingBalance == (request.resource.data.totalScheduled - request.resource.data.totalPaid);
      allow delete: if isSignedIn();
    }

    match /schedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.amount > 0
        && request.resource.data.remainingAmount >= 0
        && request.resource.data.remainingAmount <= request.resource.data.amount
        && request.resource.data.status in ['Upcoming', 'Due Today', 'Overdue', 'Partially Paid', 'Completed'];
      allow delete: if isSignedIn();
    }

    match /payments/{paymentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && request.resource.data.amount > 0;
      allow update, delete: if false; // Payments are immutable logs
    }

    match /payouts/{payoutId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn() 
        && request.resource.data.amount > 0;
      allow delete: if isSignedIn();
    }

    match /loans/{loanId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn()
        && request.resource.data.principalAmount > 0
        && request.resource.data.interestRate >= 0
        && request.resource.data.totalRepayable > 0
        && request.resource.data.status in ['Active', 'Completed', 'Defaulted'];
      allow update: if isSignedIn()
        && request.resource.data.amountRepaid >= 0
        && request.resource.data.remainingBalance >= 0
        && request.resource.data.status in ['Active', 'Completed', 'Defaulted'];
      allow delete: if isSignedIn();
    }
  }
}
